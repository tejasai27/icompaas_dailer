DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CORS_ALLOW_ALL_ORIGINS=true
PUBLIC_WEBHOOK_BASE_URL=

PGDATABASE=icompaas_dialer
PGUSER=icompaas_user
PGPASSWORD=icompaas_password
PGHOST=postgres
PGPORT=5432

REDIS_URL=redis://redis:6379/0

TELEPHONY_PROVIDER=exotel
EXOTEL_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=
EXOTEL_CALLER_ID=
EXOTEL_MAX_CALL_DURATION_SECONDS=0
EXOTEL_WAIT_URL=
EXOTEL_START_PLAYBACK_VALUE=
EXOTEL_START_PLAYBACK_TO=both

TRANSCRIPTION_BACKEND=local_whisper
WHISPER_MODEL=small
WHISPER_LANGUAGE=
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=0

# Optional: only needed if TRANSCRIPTION_BACKEND=openai
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_WHISPER_LANGUAGE=
OPENAI_WHISPER_TIMEOUT_SECONDS=600
RECORDING_UPLOAD_MAX_BYTES=15728640
AUTO_TRANSCRIBE_RECORDINGS=1
AUTO_TRANSCRIBE_LOCK_SECONDS=900

PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_SOURCE_NUMBER=

HUBSPOT_ACCESS_TOKEN=
HUBSPOT_ENABLED=0
HUBSPOT_TIMEOUT_SECONDS=12
